# ── FastAPI 백엔드 (유저/부서/문서권한) — nginx 직접 경유 (proxy 불필요)
VITE_APP_API_BASE=

# ── n8n 워크플로우 — 직접 주소
# VITE_APP_N8N_BASE=http://49.50.131.163:9110/webhook
VITE_APP_N8N_BASE=http://localhost:5678/webhook

# ── 챗봇 (n8n 프로덕션)
# VITE_APP_WEBHOOK_CHAT=http://49.50.131.163:9110/webhook/neo4j/ask
VITE_APP_WEBHOOK_CHAT=http://localhost:5678/webhook/neo4j/ask

# ── 이메일 전송 (n8n)
# VITE_APP_WEBHOOK_EMAIL=http://49.50.131.163:9110/webhook/postMail
VITE_APP_WEBHOOK_EMAIL=http://localhost:5678/webhook/postMail

# ── 파일 업로드 (n8n 프로덕션)
# VITE_APP_WEBHOOK_FILE_UPLOAD=http://49.50.131.163:9110/webhook/neo4j/fileUpload
VITE_APP_WEBHOOK_FILE_UPLOAD=http://localhost:5678/webhook/neo4j/fileUpload

# ── 파일 다운로드 (n8n)
# VITE_APP_WEBHOOK_FILE_DOWNLOAD=http://49.50.131.163:9110/webhook/download
VITE_APP_WEBHOOK_FILE_DOWNLOAD=http://localhost:5678/webhook/download
